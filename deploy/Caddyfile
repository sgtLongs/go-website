{
	auto_https off
}

:80 {
	@beta_root path /beta
	redir @beta_root /beta/ 308

	handle /beta/* {
		reverse_proxy beta:8080 {
			# Let beta WebSockets survive a production-only config reload.
			stream_close_delay 5m
		}
	}

	handle {
		reverse_proxy production:8080 {
			# Let production WebSockets survive a beta-only config reload.
			stream_close_delay 5m
		}
	}
}
