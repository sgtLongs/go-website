(app_routes) {
	@dev_root path /dev
	redir @dev_root /dev/ 308

	handle /dev/* {
		reverse_proxy dev:8080 {
			# Let development WebSockets survive another environment's config reload.
			stream_close_delay 5m
		}
	}

	@beta_root path /beta
	redir @beta_root /beta/ 308

	handle /beta/* {
		reverse_proxy beta:8080 {
			# Let beta WebSockets survive another environment's config reload.
			stream_close_delay 5m
		}
	}

	handle {
		reverse_proxy production:8080 {
			# Let production WebSockets survive another environment's config reload.
			stream_close_delay 5m
		}
	}
}

# The public hostname gets automatic HTTPS. Keep explicit HTTP-only listeners
# for deployment smoke checks and access from the local network.
{$SITE_DOMAIN:localhost} {
	import app_routes
}

http://127.0.0.1, http://192.168.68.60 {
	import app_routes
}
